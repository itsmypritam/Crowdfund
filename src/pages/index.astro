---
import "../styles/global.css";
import TipJar from "../components/TipJar";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CrowdEscrow – Milestone-Based Crowdfunding on Stellar</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎯</text></svg>" />
  </head>
  <body class="bg-background text-foreground">
    <!-- NAV -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-border/40 bg-background/80 backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4">
        <a href="#" class="text-lg font-bold tracking-tight">🎯 CrowdEscrow</a>
        <nav class="flex items-center gap-6 text-sm text-muted-foreground">
          <a href="#features" class="hover:text-foreground transition-colors">Features</a>
          <a href="#crowdescrow" class="hover:text-foreground transition-colors">Campaign</a>
          <a href="#testimonials" class="hover:text-foreground transition-colors">Testimonials</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- HERO -->
      <section class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 pt-14">
        <div
          class="absolute inset-0 bg-cover bg-center"
          style="background-image: url('https://images.unsplash.com/photo-1559027615-cd4628902d4a?q=80&w=1920&auto=format&fit=crop'); filter: brightness(0.25) saturate(0.8);"
        />
        <div class="relative z-10 mx-auto max-w-2xl text-center">
          <span class="inline-block rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-semibold text-primary tracking-wide mb-6">
            ⚡ Stellar Soroban dApp
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl leading-[1.1]">
            Fund the Future<br />
            with{" "}
            <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
              Stellar
            </span>
          </h1>
          <p class="mt-4 text-base text-muted-foreground sm:text-lg max-w-lg mx-auto leading-relaxed">
            Milestone-based crowdfunding with escrow protection on Stellar Soroban.
            Connect your wallet, pick a campaign, and donate in real-time.
          </p>
          <a
            href="#crowdescrow"
            class="mt-8 inline-flex h-11 items-center justify-center rounded-lg bg-primary px-6 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/80"
          >
            View Campaign →
          </a>
        </div>
      </section>

      <!-- FEATURES -->
      <section id="features" class="border-t border-border/40 px-4 py-20">
        <div class="mx-auto max-w-5xl text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Why CrowdEscrow on Stellar?</h2>
          <div class="mt-12 grid gap-6 sm:grid-cols-3">
            {[
              { icon: "🔗", title: "Multi-Wallet", desc: "Supports Freighter, Albedo, LOBSTR, and xBull — you choose." },
              { icon: "📜", title: "Smart Contract", desc: "Campaign logic runs on-chain via Soroban. Transparent and trustless." },
              { icon: "⚡", title: "Real-Time", desc: "Donations appear instantly via WebSocket. Watch the progress live." },
            ].map((f) => (
              <div
                key={f.title}
                class="group rounded-xl border border-border/50 bg-card p-6 text-left transition-colors hover:border-primary/30 hover:bg-primary/[0.03]"
              >
                <div class="text-3xl mb-3">{f.icon}</div>
                <h3 class="text-lg font-semibold">{f.title}</h3>
                <p class="mt-1 text-sm text-muted-foreground leading-relaxed">{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CROWDFUND (React island) -->
      <TipJar client:only="react" />

      <!-- TESTIMONIALS -->
      <section id="testimonials" class="border-t border-border/40 px-4 py-20">
        <div class="mx-auto max-w-5xl text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">What People Say</h2>
          <div class="mt-12 grid gap-6 sm:grid-cols-3">
            {[
              { img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=200&auto=format&fit=crop", text: "Connected with Freighter and donated in seconds. The Soroban integration is smooth!", name: "Alex Rivera", role: "Web3 Developer" },
              { img: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=200&auto=format&fit=crop", text: "Love the real-time feed. I could see my donation appear instantly on the leaderboard.", name: "Sarah Chen", role: "Content Creator" },
              { img: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=200&auto=format&fit=crop", text: "Multi-wallet support is a game-changer. I use LOBSTR and it worked flawlessly.", name: "Marcus Johnson", role: "Open Source Maintainer" },
            ].map((t) => (
              <div
                key={t.name}
                class="flex flex-col items-center gap-4 rounded-xl border border-border/50 bg-card p-6"
              >
                <img
                  src={t.img}
                  alt={t.name}
                  class="size-14 rounded-full object-cover ring-2 ring-primary/30"
                />
                <p class="text-sm text-muted-foreground italic leading-relaxed">"{t.text}"</p>
                <div>
                  <p class="text-sm font-semibold">{t.name}</p>
                  <p class="text-xs text-muted-foreground">{t.role}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="relative overflow-hidden px-4 py-24">
        <div
          class="absolute inset-0 bg-cover bg-center"
          style="background-image: url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=1920&auto=format&fit=crop'); filter: brightness(0.2) saturate(0.7);"
        />
        <div class="relative z-10 mx-auto max-w-xl text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Ready to Make an Impact?</h2>
          <p class="mt-3 text-muted-foreground leading-relaxed">
            Connect your wallet and support the campaign. Every contribution brings us closer to the goal.
          </p>
          <a
            href="#crowdescrow"
            class="mt-8 inline-flex h-11 items-center justify-center rounded-lg bg-indigo-500 px-6 text-sm font-medium text-indigo-950 shadow-sm transition-colors hover:bg-indigo-400"
          >
            Donate Now →
          </a>
        </div>
      </section>
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-border/40 py-6 text-center text-xs text-muted-foreground">
      <p>Built with 🎯 for the Stellar Green Belt Challenge</p>
    </footer>
  </body>
</html>
