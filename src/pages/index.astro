---
import TipJar from "../components/TipJar";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tip Jar – Stellar Testnet dApp</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☕</text></svg>" />
  </head>
  <body>
    <nav class="navbar">
      <a href="#hero" class="nav-logo">☕ TipJar</a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#tip-jar">Send Tip</a>
        <a href="#testimonials">Testimonials</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero" id="hero">
      <div class="hero-overlay" style="background-image: url('https://images.unsplash.com/photo-1498804103079-a6351b050096?q=80&w=1920&auto=format&fit=crop')"></div>
      <div class="hero-content">
        <span class="hero-badge">⚡ Stellar Testnet dApp</span>
        <h1>Support Creators<br/>with <span class="gradient-text">Crypto Tips</span></h1>
        <p>Send XLM instantly to anyone. Connect your Freighter wallet, pick an amount, and tip — all on the Stellar testnet.</p>
        <a href="#tip-jar" class="btn btn-hero">Start Tipping →</a>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features" id="features">
      <h2>Why Tip with Stellar?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Instant</h3>
          <p>Transactions settle in 3–5 seconds. No waiting, no delays.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <h3>Nearly Free</h3>
          <p>Each transaction costs 0.00001 XLM — fractions of a cent.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔐</div>
          <h3>Non-Custodial</h3>
          <p>Your keys, your coins. Freighter keeps you in full control.</p>
        </div>
      </div>
    </section>

    <!-- TIP JAR (interactive React component) -->
    <TipJar client:only="react" />

    <!-- TESTIMONIALS -->
    <section class="testimonials" id="testimonials">
      <h2>What People Say</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-img" style="background-image: url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=200&auto=format&fit=crop')"></div>
          <p class="testimonial-text">"Sent my first XLM tip in seconds. The Freighter integration is seamless!"</p>
          <span class="testimonial-name">Alex Rivera</span>
          <span class="testimonial-role">Web3 Developer</span>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-img" style="background-image: url('https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=200&auto=format&fit=crop')"></div>
          <p class="testimonial-text">"Love how simple it is. Connect, type an amount, and boom — tip sent."</p>
          <span class="testimonial-name">Sarah Chen</span>
          <span class="testimonial-role">Content Creator</span>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-img" style="background-image: url('https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=200&auto=format&fit=crop')"></div>
          <p class="testimonial-text">"Finally a no-fuss way to accept crypto tips. The QR code makes it even better."</p>
          <span class="testimonial-name">Marcus Johnson</span>
          <span class="testimonial-role">Open Source Maintainer</span>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <div class="cta-bg" style="background-image: url('https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=1920&auto=format&fit=crop')"></div>
      <div class="cta-content">
        <h2>Ready to Get Tips?</h2>
        <p>Connect your Freighter wallet and start receiving XLM from supporters around the world.</p>
        <a href="#tip-jar" class="btn btn-cta">Try It Now →</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <p>Built with ☕ for the Stellar White Belt Challenge</p>
    </footer>
  </body>
</html>

<style is:global>
  *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: #0b0b14;
    color: #e8e8f0;
    overflow-x: hidden;
  }

  /* NAV */
  .navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(11, 11, 20, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nav-logo { font-size: 1.2rem; font-weight: 700; color: #e8e8f0; text-decoration: none; }

  .nav-links { display: flex; gap: 1.5rem; }

  .nav-links a {
    color: rgba(255,255,255,0.55);
    text-decoration: none; font-size: 0.9rem; font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: #fff; }

  /* HERO */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 2rem; text-align: center;
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    filter: brightness(0.3) saturate(0.8);
    z-index: 0;
  }

  .hero-content {
    position: relative; z-index: 1;
    max-width: 680px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem; border-radius: 100px;
    background: rgba(124, 77, 255, 0.15);
    border: 1px solid rgba(124, 77, 255, 0.3);
    font-size: 0.8rem; font-weight: 600; letter-spacing: 0.03em;
    margin-bottom: 1.5rem; color: #b388ff;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.1; font-weight: 800;
    margin-bottom: 1rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, #7c4dff, #448aff, #00bfa5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.1rem; line-height: 1.7;
    color: rgba(255,255,255,0.55);
    max-width: 520px; margin: 0 auto 2rem;
  }

  .btn {
    display: inline-block; padding: 0.85rem 2rem;
    border-radius: 12px; font-size: 1rem; font-weight: 600;
    text-decoration: none; cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    border: none;
  }

  .btn:active { transform: scale(0.97); }

  .btn-hero {
    background: linear-gradient(135deg, #7c4dff, #651fff);
    color: #fff; font-size: 1.05rem; padding: 1rem 2.5rem;
  }

  .btn-hero:hover { opacity: 0.9; }

  /* FEATURES */
  .features {
    padding: 5rem 2rem; text-align: center;
    background: rgba(255,255,255,0.02);
  }

  .features h2 { font-size: 2rem; margin-bottom: 3rem; }

  .features-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem; max-width: 900px; margin: 0 auto;
  }

  .feature-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; padding: 2rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .feature-card:hover {
    border-color: rgba(124, 77, 255, 0.3);
    background: rgba(124, 77, 255, 0.06);
  }

  .feature-icon { font-size: 2rem; margin-bottom: 0.75rem; }

  .feature-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }

  .feature-card p { font-size: 0.9rem; color: rgba(255,255,255,0.5); line-height: 1.6; }

  /* TIP JAR (wraps the React component) */
  .tipjar-container {
    max-width: 720px; margin: 0 auto;
    padding: 5rem 1rem;
    scroll-margin-top: 4rem;
  }

  .tipjar-card {
    background: linear-gradient(135deg, rgba(124,77,255,0.08), rgba(0,191,165,0.06));
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px; padding: 2.5rem;
    backdrop-filter: blur(16px);
  }

  .tipjar-card-inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
  }

  @media (max-width: 640px) {
    .tipjar-card-inner { grid-template-columns: 1fr; }
  }

  .tipjar-left { display: flex; flex-direction: column; gap: 1rem; }

  .tipjar-left h2 { font-size: 1.6rem; }

  .tipjar-left > p { color: rgba(255,255,255,0.5); font-size: 0.9rem; line-height: 1.6; }

  .qr-section { display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; }

  .qr-section svg { border-radius: 12px; background: white; padding: 8px; }

  .qr-label { font-size: 0.75rem; opacity: 0.5; font-family: monospace; }

  .tipjar-right { display: flex; flex-direction: column; gap: 1.25rem; }

  .wallet-info { display: flex; flex-direction: column; gap: 0.6rem; }

  .wallet-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; }

  .wi-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.4; }

  .wi-address { font-family: monospace; font-size: 0.95rem; }

  .wi-value { font-weight: 600; }

  .tip-form { display: flex; flex-direction: column; gap: 0.65rem; }

  .tip-form input {
    padding: 0.7rem 1rem; border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06); color: #fff;
    font-size: 0.95rem; outline: none;
    transition: border-color 0.2s;
  }

  .tip-form input::placeholder { color: rgba(255,255,255,0.3); }

  .tip-form input:focus { border-color: #7c4dff; }

  .btn-accent {
    background: linear-gradient(135deg, #7c4dff, #651fff);
    color: #fff; width: 100%; text-align: center;
    padding: 0.8rem;
  }

  .btn-accent:hover:not(:disabled) { opacity: 0.9; }
  .btn-accent:disabled { opacity: 0.35; cursor: not-allowed; }

  .btn-ghost {
    background: transparent; color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.1); width: 100%;
    font-size: 0.85rem; text-align: center;
  }

  .btn-ghost:hover { border-color: rgba(255,255,255,0.25); color: #fff; }

  .tx-status {
    padding: 0.75rem 1rem; border-radius: 10px;
    font-size: 0.85rem; text-align: center;
  }

  .tx-status.success { background: rgba(0,200,83,0.1); border: 1px solid rgba(0,200,83,0.2); }
  .tx-status.error { background: rgba(255,82,82,0.1); border: 1px solid rgba(255,82,82,0.2); }

  .tx-status a { display: inline-block; margin-top: 0.3rem; color: #82b1ff; text-decoration: none; font-size: 0.8rem; }
  .tx-status a:hover { text-decoration: underline; }

  /* TESTIMONIALS */
  .testimonials {
    padding: 5rem 2rem; text-align: center;
  }

  .testimonials h2 { font-size: 2rem; margin-bottom: 3rem; }

  .testimonials-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem; max-width: 960px; margin: 0 auto;
  }

  .testimonial-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px; padding: 2rem 1.5rem;
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }

  .testimonial-img {
    width: 64px; height: 64px; border-radius: 50%;
    background-size: cover; background-position: center;
    border: 2px solid rgba(124,77,255,0.3);
  }

  .testimonial-text {
    font-size: 0.95rem; line-height: 1.6;
    color: rgba(255,255,255,0.6);
    font-style: italic;
  }

  .testimonial-name { font-weight: 700; font-size: 0.95rem; }

  .testimonial-role { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

  /* CTA */
  .cta {
    position: relative; padding: 6rem 2rem; text-align: center;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    filter: brightness(0.25) saturate(0.7);
    z-index: 0;
  }

  .cta-content {
    position: relative; z-index: 1;
    max-width: 560px; margin: 0 auto;
  }

  .cta-content h2 { font-size: 2.2rem; margin-bottom: 1rem; }

  .cta-content p { color: rgba(255,255,255,0.55); line-height: 1.7; margin-bottom: 2rem; }

  .btn-cta {
    background: linear-gradient(135deg, #00bfa5, #00e676);
    color: #0b0b14; font-size: 1.05rem; padding: 1rem 2.5rem;
  }

  .btn-cta:hover { opacity: 0.9; }

  /* FOOTER */
  .footer {
    text-align: center; padding: 2rem;
    font-size: 0.85rem; color: rgba(255,255,255,0.25);
    border-top: 1px solid rgba(255,255,255,0.05);
  }
</style>
